# Database (local PostgreSQL cache)
POSTGRES_PASSWORD="<set-a-strong-password>"
DATABASE_URL="postgresql://kklrms:<password>@localhost:5432/kklrms?schema=public"

# Auth (NextAuth.js)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="<generate-with: openssl rand -base64 32>"

# BMS Session API (authentication validation endpoint)
BMS_VALIDATE_URL="https://hosxp.net/phapi/PasteJSON"

# PDPA Encryption Key (AES-256 hex key for patient name/CID)
ENCRYPTION_KEY="<generate-with: openssl rand -hex 32>"

# Development: Auto-configure test hospital on startup
DEV_HOSPITAL_TUNNEL_URL="<your-hospital-tunnel-url>"

# Development: Skip BMS authentication (accepts any session ID as ADMIN)
# DEV_AUTH_BYPASS="true"
